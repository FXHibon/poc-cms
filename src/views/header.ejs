<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= locals.page ? page.title : (locals.title || 'Error') %> | <%= settings.site_name || 'NovaCMS' %></title>
  <meta name="description" content="<%= settings.site_description || 'A simple premium CMS' %>">
  
  <!-- Premium Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  
  <style>
    <% if (settings.site_theme === 'cyberpunk') { %>
    :root {
      --bg: #08080a;
      --card-bg: rgba(20, 20, 25, 0.85);
      --card-border: rgba(0, 240, 255, 0.25);
      --text: #f1f5f9;
      --text-muted: #64748b;
      --accent: <%= settings.accent_color || '#ff0055' %>;
      --accent-rgb: 255, 0, 85;
      --glow: rgba(255, 0, 85, 0.2);
      --font: 'Share Tech Mono', monospace;
      --logo-start: #00f0ff;
      --heading-color: #00f0ff;
      --text-hover: #ffffff;
      --header-bg: rgba(8, 8, 10, 0.85);
      --btn-bg: rgba(0, 240, 255, 0.05);
      --shadow: 0 0 20px rgba(0, 240, 255, 0.15);
      --bg-pattern: linear-gradient(rgba(0, 240, 255, 0.02) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(0, 240, 255, 0.02) 1px, transparent 1px);
    }
    <% } else if (settings.site_theme === 'emerald') { %>
    :root {
      --bg: #030c08;
      --card-bg: rgba(8, 22, 15, 0.7);
      --card-border: rgba(52, 211, 153, 0.12);
      --text: #e6f4ea;
      --text-muted: #8cd6a7;
      --accent: <%= settings.accent_color || '#10b981' %>;
      --accent-rgb: 16, 185, 129;
      --glow: rgba(16, 185, 129, 0.2);
      --font: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --logo-start: #ffffff;
      --heading-color: #34d399;
      --text-hover: #6ee7b7;
      --header-bg: rgba(3, 12, 8, 0.75);
      --btn-bg: rgba(16, 185, 129, 0.08);
      --shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
      --bg-pattern: radial-gradient(circle at 20% 30%, rgba(16, 185, 129, 0.06) 0%, transparent 45%),
                    radial-gradient(circle at 80% 70%, rgba(52, 211, 153, 0.04) 0%, transparent 50%);
    }
    <% } else { %>
    :root {
      --bg: #0b0f19;
      --card-bg: rgba(17, 24, 39, 0.65);
      --card-border: rgba(255, 255, 255, 0.08);
      --text: #f3f4f6;
      --text-muted: #9ca3af;
      --accent: <%= settings.accent_color || '#8b5cf6' %>;
      --accent-rgb: 139, 92, 246; /* Default RGB */
      --glow: rgba(139, 92, 246, 0.15);
      --font: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --logo-start: #ffffff;
      --heading-color: #ffffff;
      --text-hover: #ffffff;
      --header-bg: rgba(11, 15, 25, 0.7);
      --btn-bg: rgba(255, 255, 255, 0.08);
      --shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
      --bg-pattern: radial-gradient(circle at 10% 20%, rgba(139, 92, 246, 0.04) 0%, transparent 40%),
                    radial-gradient(circle at 90% 80%, rgba(139, 92, 246, 0.02) 0%, transparent 50%);
    }
    <% } %>

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--font);
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
      /* Background pattern */
      background-image: var(--bg-pattern);
      background-size: <%= settings.site_theme === 'cyberpunk' ? '30px 30px' : 'auto' %>;
      background-attachment: fixed;
    }

    /* Theme specific structural overrides */
    <% if (settings.site_theme === 'cyberpunk') { %>
      .content-card, .main-header, .admin-btn, .pdf-file-link, .back-btn, .pdf-public-widget {
        border-radius: 0px !important;
      }
      .content-card {
        border: 2px solid var(--accent) !important;
        box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.2), inset 0 0 15px rgba(var(--accent-rgb), 0.1) !important;
      }
      .pdf-file-link {
        border: 1px solid var(--accent) !important;
      }
      .logo {
        text-shadow: 0 0 8px rgba(var(--accent-rgb), 0.6);
      }
      .admin-btn:hover {
        box-shadow: 0 0 15px var(--accent) !important;
      }
    <% } else if (settings.site_theme === 'emerald') { %>
      .content-card {
        border-radius: 28px !important;
      }
      .admin-btn, .pdf-file-link, .back-btn, .pdf-public-widget {
        border-radius: 14px !important;
      }
      .content-card::before {
        height: 6px !important;
        border-radius: 28px 28px 0 0 !important;
      }
    <% } %>

    /* Transparent Sticky Nav Bar */
    .main-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--header-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--card-border);
      padding: 1rem 2rem;
    }

    .nav-container {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      font-size: 1.5rem;
      font-weight: 700;
      text-decoration: none;
      color: var(--text);
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, var(--logo-start) 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      transition: opacity 0.2s ease;
    }

    .logo:hover {
      opacity: 0.9;
    }

    nav {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .nav-link {
      color: var(--text-muted);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
      transition: all 0.2s ease;
      position: relative;
      padding: 0.25rem 0;
    }

    .nav-link:hover, .nav-link.active {
      color: var(--text);
    }

    .nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background-color: var(--accent);
      transition: width 0.2s ease;
    }

    .nav-link:hover::after, .nav-link.active::after {
      width: 100%;
    }

    .admin-btn {
      background: var(--btn-bg);
      border: 1px solid var(--card-border);
      color: var(--text);
      text-decoration: none;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      transition: all 0.2s ease;
      backdrop-filter: blur(4px);
    }

    .admin-btn:hover {
      background: var(--accent);
      border-color: var(--accent);
      box-shadow: 0 0 15px var(--glow);
      transform: translateY(-1px);
    }

    /* Main Content */
    main {
      flex: 1;
      width: 100%;
      max-width: 900px;
      margin: 3rem auto;
      padding: 0 2rem;
      animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    /* Premium Container Card */
    .content-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 20px;
      padding: 3rem;
      box-shadow: var(--shadow);
      position: relative;
    }

    .content-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      border-radius: 20px 20px 0 0;
    }

    /* Preview Warning Pill */
    .preview-badge {
      display: inline-flex;
      align-items: center;
      background: rgba(245, 158, 11, 0.15);
      border: 1px solid rgba(245, 158, 11, 0.3);
      color: #fbbf24;
      padding: 0.25rem 0.75rem;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 1.5rem;
      animation: pulse 2s infinite ease-in-out;
    }

    /* EJS dynamic article layouts */
    .article-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid var(--card-border);
      padding-bottom: 1.5rem;
    }

    .article-title {
      font-size: 2.5rem;
      font-weight: 700;
      line-height: 1.2;
      color: var(--heading-color);
      margin-bottom: 0.5rem;
    }

    .article-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .article-content {
      font-size: 1.1rem;
      line-height: 1.8;
      color: var(--text);
    }

    .article-content h1, .article-content h2, .article-content h3 {
      color: var(--heading-color);
      margin: 2rem 0 1rem 0;
      font-weight: 600;
    }

    .article-content h1 { font-size: 2rem; }
    .article-content h2 { font-size: 1.6rem; }
    .article-content h3 { font-size: 1.3rem; }

    .article-content p {
      margin-bottom: 1.5rem;
    }

    .article-content a {
      color: var(--accent);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .article-content a:hover {
      text-decoration: underline;
      color: var(--text-hover);
    }

    .article-content ul, .article-content ol {
      margin-left: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .article-content li {
      margin-bottom: 0.5rem;
    }

    /* Error styles */
    .error-container {
      text-align: center;
      padding: 2rem 0;
    }

    .error-code {
      font-size: 6rem;
      font-weight: 800;
      line-height: 1;
      background: linear-gradient(135deg, #ef4444 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 1.5rem;
    }

    .error-message {
      font-size: 1.2rem;
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    .back-btn {
      display: inline-block;
      background: var(--accent);
      color: #ffffff;
      text-decoration: none;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .back-btn:hover {
      box-shadow: 0 0 15px var(--glow);
      transform: translateY(-1px);
    }

    /* Animations */
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.9; }
      50% { opacity: 0.5; }
    }

    /* Responsive */
    @media (max-width: 600px) {
      .main-header {
        padding: 1rem;
      }
      .nav-container {
        flex-direction: column;
        gap: 1rem;
      }
      nav {
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
      }
      .content-card {
        padding: 1.5rem;
      }
      .article-title {
        font-size: 1.8rem;
      }
    }

    /* PDF Folder Widget Styling */
    .pdf-public-widget {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 12px;
      padding: 1.5rem;
      margin: 1.5rem 0;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }
    .pdf-public-widget.empty-widget {
      text-align: center;
      padding: 2rem;
      color: var(--text-muted);
    }
    .widget-icon {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }
    .widget-title {
      font-size: 1.2rem !important;
      margin: 0 0 1.25rem 0 !important;
      font-weight: 600;
      color: var(--heading-color);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .pdf-files-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .pdf-file-link {
      display: flex;
      align-items: center;
      padding: 0.75rem 1rem;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--card-border);
      border-radius: 8px;
      text-decoration: none !important;
      color: var(--text) !important;
      transition: all 0.2s ease;
    }

    .pdf-file-link:hover {
      background: rgba(var(--accent-rgb), 0.06);
      border-color: rgba(var(--accent-rgb), 0.3);
      transform: translateY(-1px);
    }
    .pdf-icon {
      color: #ef4444;
      margin-right: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
    }
    .pdf-icon svg {
      stroke: currentColor;
    }
    .pdf-details {
      flex: 1;
      display: flex;
      flex-direction: column;
      text-align: left;
    }
    .pdf-name {
      font-weight: 500;
      font-size: 0.95rem;
      word-break: break-all;
      color: var(--text);
    }
    .pdf-size {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 0.1rem;
    }
    .pdf-download-arrow {
      color: var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: 1rem;
      transition: color 0.2s ease;
    }
    .pdf-file-link:hover .pdf-download-arrow {
      color: var(--accent);
    }
    .pdf-public-widget.error-widget {
      border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.05);
      color: #f87171;
      padding: 1rem;
      border-radius: 8px;
      font-size: 0.9rem;
      margin: 1.5rem 0;
    }
  </style>
  <script>
    // Convert hex accent color to RGB to update the glow dynamic styling variable
    document.addEventListener("DOMContentLoaded", () => {
      let hex = "<%= settings.accent_color || '' %>";
      if (!hex) {
        const theme = "<%= settings.site_theme || 'midnight-violet' %>";
        hex = theme === "cyberpunk" ? "#ff0055" : (theme === "emerald" ? "#10b981" : "#8b5cf6");
      }
      let r = 139, g = 92, b = 246; // default fallback
      if(/^#([A-Fa-f0-9]{3}){1,2}$/.test(hex)) {
        let c = hex.substring(1).split('');
        if(c.length === 3) {
          c = [c[0], c[0], c[1], c[1], c[2], c[2]];
        }
        c = '0x' + c.join('');
        r = (c>>16)&255;
        g = (c>>8)&255;
        b = c&255;
      }
      document.documentElement.style.setProperty('--accent-rgb', `${r}, ${g}, ${b}`);
      document.documentElement.style.setProperty('--glow', `rgba(${r}, ${g}, ${b}, 0.2)`);
    });
  </script>
</head>
<body>

  <header class="main-header">
    <div class="nav-container">
      <a href="/" class="logo"><%= settings.site_name || 'NovaCMS' %></a>
      <nav>
        <a href="/" class="nav-link <%= (locals.page && page.slug === 'home') ? 'active' : '' %>">Home</a>
        <% menuPages.forEach(function(item) { %>
          <% if (item.slug !== 'home') { %>
            <a href="/<%= item.slug %>" class="nav-link <%= (locals.page && page.slug === item.slug) ? 'active' : '' %>"><%= item.title %></a>
          <% } %>
        <% }); %>

        <a href="/admin" class="admin-btn">Admin Panel</a>
      </nav>
    </div>
  </header>

  <main>
    <div class="content-card">
