<%- include('header') %>

<% if (preview) { %>
  <div class="preview-badge">Draft Preview</div>
<% } %>

<article>
  <header class="article-header">
    <h1 class="article-title"><%= page.title %></h1>
    <div class="article-meta">
      Published: <%= page.created_at ? new Date(page.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A' %>
    </div>
  </header>
  <section class="article-content">
    <%- page.content %>
  </section>
</article>

<%- include('footer') %>
